# Neon-compatible Postgres (sslmode=require recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Supabase (project URL from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# OpenAI (server-side only; required for real extraction + admin specialist agent)
OPENAI_API_KEY=""
# Optional; defaults to gpt-4o-mini in code when unset
OPENAI_MODEL=""

# Admin UI: when CAMPTI_ADMIN_PASSWORD is set, /admin and /api/admin require a signed session (login at /admin/login).
CAMPTI_ADMIN_PASSWORD=""
# Optional; used to sign the admin session cookie (defaults to CAMPTI_ADMIN_PASSWORD if unset)
CAMPTI_ADMIN_SESSION_SECRET=""
