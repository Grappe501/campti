# Neon-compatible Postgres (sslmode=require recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Supabase (project URL from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# OpenAI (server-side only; required for real extraction)
OPENAI_API_KEY=""
# Optional; defaults to gpt-4o-mini in code when unset
OPENAI_MODEL=""
