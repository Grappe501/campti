generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VisibilityStatus {
  PRIVATE @map("private")
  REVIEW  @map("review")
  PUBLIC  @map("public")
}

enum RecordType {
  HISTORICAL   @map("historical")
  ORAL_HISTORY @map("oral_history")
  INFERRED     @map("inferred")
  FICTIONAL    @map("fictional")
  HYBRID       @map("hybrid")
}

enum SourceType {
  PDF   @map("pdf")
  DOCX  @map("doc")
  NOTE  @map("note")
  IMAGE @map("image")
  AUDIO @map("audio")
  VIDEO @map("video")
  WEB   @map("web")
  OTHER @map("source_other")
}

enum PlaceType {
  TOWN     @map("town")
  LAKE     @map("lake")
  CHURCH   @map("church")
  REGION   @map("region")
  CEMETERY @map("cemetery")
  HOME     @map("home")
  FIELD    @map("field")
  RIVER    @map("river")
  OTHER    @map("place_other")
}

enum EventType {
  BIRTH     @map("birth")
  DEATH     @map("death")
  MARRIAGE  @map("marriage")
  MIGRATION @map("migration")
  LAND      @map("land")
  CHURCH    @map("church_event")
  WAR       @map("war")
  FAMILY    @map("family")
  POLITICAL @map("political")
  CULTURAL  @map("cultural")
  OTHER     @map("event_other")
}

enum SymbolCategory {
  ELEMENTAL @map("element")
  CULINARY  @map("food")
  LANDSCAPE @map("plant")
  RELIGIOUS @map("religious")
  FAMILY    @map("family_sym")
  RITUAL    @map("ritual")
  OTHER     @map("symbol_other")
}

enum WritingMode {
  STRUCTURED
  NARRATIVE
  HYBRID
}

/// One genealogical ãquestionã (subject + predicate + optional witness/discriminator). Multiple assertions attach here.
enum GenealogicalPredicate {
  BIRTH_YEAR
  DEATH_YEAR
  BIRTH_PLACE
  DEATH_PLACE
  BURIAL_PLACE
  FATHER_ID
  MOTHER_ID
  FREEDOM_STATUS
  RACIAL_CLASSIFICATION_RECORDED
  ENSLAVED_NAME
  FREE_NAME
  UNION_SPOUSE_ID
  RESIDENCE_AT_DATE
  LAND_TENURE
  OTHER
}

enum FactAssertionStatus {
  ACTIVE
  SUPERSEDED
  REJECTED
}

enum NarrativeDependencyConsumerKind {
  SCENE
  CHAPTER
  BOOK
  BEAT
  META_SCENE
  EXPORT_BUNDLE
}

enum NarrativeDependencyProducerKind {
  GENEALOGICAL_ASSERTION
  PERSON
  WORLD_STATE_REFERENCE
  PLACE
  HISTORICAL_EVENT
  LEGACY_CLAIM
  EPIC
  BOOK
  CHAPTER
  /// Phase 5E/6 ã simulation scenario used as generation/regen input.
  SIMULATION_SCENARIO
  /// Phase 5/6 ã pinned cognition / inner-voice / decision session used as source material.
  COGNITION_SESSION
}

/// Cached reader assembly / chapter compile validity (distinct from genealogical truth).
enum NarrativeAssemblyStatus {
  CURRENT
  STALE
  REBUILDING
}

/// Scene/chapter continuity gate for publish pipeline (human triage).
enum NarrativeContinuityState {
  OK
  WARNING
  BLOCKING
}

/// What prose blob `ProseQualityReport.reportJson` describes.
enum ProseQualityAnalysisScope {
  SCENE
  CHAPTER_ASSEMBLY
}

/// Planned vs simulation vs exploratory cognition slices (does not replace `CharacterState` rows).
enum CognitionSnapshotKind {
  CANONICAL_PLANNED
  SIMULATION_BASE
  EXPLORATORY
}

enum InnerVoiceSessionMode {
  INNER_VOICE
  DECISION_TRACE
  ALTERNATE_RUN
  GOD_MODE_QA
}

enum CognitionCanonicalStatus {
  EXPLORATORY
  PINNED
  REJECTED
}

enum SimulationScenarioStatus {
  DRAFT
  READY
  ARCHIVED
}

enum DependencyStrength {
  HARD
  SOFT
}

enum RevisionJobKind {
  REEVALUATE_SCENE
  REGENERATE_SCENE_AI
  CONTINUITY_CHECK
  MARK_STALE
}

enum RevisionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/// Story-system personality law (default; author may override in CharacterProfile fields).
enum EnneagramType {
  ONE
  TWO
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
}

enum FragmentType {
  CREATIVE_FRAGMENT
  SCENE_SEED
  CHAPTER_SEED
  MEMORY
  EMOTIONAL_BEAT
  CHARACTER_INSIGHT
  SYMBOLIC_NOTE
  MOTIF_RULE
  STRUCTURAL_OUTLINE
  HISTORICAL_ANCHOR
  ORAL_HISTORY
  RESEARCH_NOTE
  NARRATOR_VOICE
  CONTINUITY_CONSTRAINT
  QUESTION_SEED
  THEME_STATEMENT
  IMAGE_OR_SENSORY
  DIALOGUE_SNIPPET
  OTHER
}

/// Constitutional / simulation law category (TruthPolicy, VoicePolicy, etc. are rows with this type ã not separate tables).
enum RuleType {
  TRUTH
  AMBIGUITY
  REVEAL
  VOICE
  VIOLENCE
  THEOLOGY
  DETERMINISM
  DRAFT_ELIGIBILITY
}

enum RuleScope {
  GLOBAL
  ENTITY
  SCENE
  CHARACTER
  VOICE
  SYSTEM
}

enum RuleSeverity {
  INFO
  WARNING
  BLOCKING
}

/// Character engine ã bounded choice and moral/social limits.
enum CharacterConstraintType {
  MORAL
  SOCIAL
  PHYSICAL
  PSYCHOLOGICAL
}

/// Character engine ã what activates interior response.
enum CharacterTriggerType {
  EMOTIONAL
  SOCIAL
  MEMORY
  ENVIRONMENTAL
}

/// Environment & risk layer ã reusable categories for RiskRegime and analytics.
enum EnvironmentRiskCategory {
  FLOOD
  DISEASE
  CONFLICT
  ISOLATION
  SCARCITY
  SURVEILLANCE
  TRANSPORT
}

/// Corridor / adjacency between simulation nodes (river, trail, trade path, etc.).
enum NodeConnectionType {
  RIVER
  BAYOU
  TRAIL
  ROAD
  FERRY
  MILITARY_ROUTE
  TRADE_PATH
}

/// Layered meaning attached to a place (sacred, trauma, trade, etc.).
enum PlaceMemoryType {
  SACRED
  TRAUMA
  BURIAL
  TRADE
  WAR
  COMMUNITY
  DISPLACEMENT
  CONTINUITY
}

/// Stage 5 ã Governance / order pressure (world-state field).
enum JusticeMode {
  RESTORATIVE
  PUNITIVE
  HIERARCHICAL
  MIXED
}

/// Stage 5 ã Socio-economic status band (character, world-state slice).
enum StatusPosition {
  HIGH
  MID
  LOW
  AMBIGUOUS
}

/// Stage 5 ã Demographic identity self-perception (character, world-state slice).
enum SelfPerceptionState {
  AFFIRMED
  CONDITIONAL
  QUESTIONED
}

/// Stage 6 ã Relationship engine: bond category (world-sliced dyad).
enum RelationshipType {
  KINSHIP
  ALLIANCE
  FRIENDSHIP
  MARRIAGE_BOND
  COURTSHIP
  CHOSEN_FAMILY
  PROTECTIVE
  DOMINANCE
  TRANSLATION_BRIDGE
  RIVALRY
  SPIRITUAL_AUTHORITY
  ECONOMIC_DEPENDENCY
}

/// Stage 6 ã Desire / attachment slice (character û world).
enum AttachmentStyle {
  SECURE
  ANXIOUS
  AVOIDANT
  DISORGANIZED
  DUTY_BOUND
  SPLIT_EXPRESSION
}

/// Stage 6 ã How a bond is socially legible.
enum PublicStatus {
  OPEN
  IMPLIED
  HIDDEN
  DENIED
  FORCED
  CODED
}

/// Stage 6.5 ã Dominant route by which usable skill/knowledge is acquired (character slice).
enum TrainingMode {
  ORAL_TRADITION
  APPRENTICESHIP
  RITUAL_INSTRUCTION
  HOUSEHOLD_TRAINING
  FORMAL_SCHOOLING
  RELIGIOUS_CATECHESIS
  MILITARY_TRAINING
  SELF_TAUGHT
  MIXED
}

/// Stage 2 ã Ontology spine: what classes of objects exist in the simulation graph.
enum OntologyFamily {
  ENTITY
  NARRATIVE
  SIMULATION
  ENVIRONMENT
  RELATIONSHIP
  SUPPORT
}

/// Stage 2 ã Controlled vocabulary families for RegistryValue rows.
enum RegistryFamily {
  SYMBOLIC
  RELATIONSHIP
  ENVIRONMENT
  PRESSURE
  PERMISSION
  READINESS
  BRANCH
  GENERAL
}

model Source {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility       VisibilityStatus
  recordType       RecordType
  title            String
  sourceType       SourceType       @map("type")
  filePath         String?
  summary          String?
  originalFilename String?
  notes            String?
  sourceDate       String?
  sourceYear       Int?
  authorOrOrigin   String?
  archiveStatus    String?
  ingestionReady   Boolean          @default(false)

  ingestionStatus    String?
  lastIngestionRunId String? @unique
  processingNotes    String?
  extractedSummary   String?
  reviewedSummary    String?

  claims                   Claim[]
  genealogicalAssertions GenealogicalAssertion[]
  persons       Person[]
  places        Place[]
  events        Event[]
  chapters      Chapter[]
  scenes        Scene[]
  openQuestions OpenQuestion[]

  sourceText        SourceText?
  ingestionRuns     IngestionRun[]     @relation("SourceIngestionRuns")
  lastIngestionRun  IngestionRun?      @relation("SourceLastIngestionRun", fields: [lastIngestionRunId], references: [id], onDelete: SetNull)
  extractionPackets ExtractionPacket[]
  extractionResults ExtractionResult[]
  extractedEntities ExtractedEntity[]
  sourceChunks      SourceChunk[]
  fragments         Fragment[]
  brainMemos        BrainMemo[]

  narrativeRules      NarrativeRule[]
  narrativeThemes     Theme[]
  motifs              Motif[]
  literaryDevices     LiteraryDevice[]
  narrativePatterns   NarrativePattern[]
  narrativeDnaSymbols Symbol[]

  censusResearchDatasets CensusResearchDataset[]

  @@index([visibility])
  @@index([recordType])
  @@index([sourceType])
  @@index([ingestionStatus])
  @@index([archiveStatus])
}

model SourceChunk {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  sourceTextId String?
  sourceText   SourceText? @relation(fields: [sourceTextId], references: [id], onDelete: SetNull)

  chunkIndex     Int
  startOffset    Int?
  endOffset      Int?
  charCount      Int?
  tokenEstimate  Int?
  headingHint    String?
  chunkLabel     String?
  rawText        String? @db.Text
  normalizedText String? @db.Text
  textStatus     String?
  notes          String?

  chunkExtractionRuns ChunkExtractionRun[]
  fragments           Fragment[]

  @@index([sourceId])
  @@index([chunkIndex])
}

model SourceText {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId       String  @unique
  source         Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawText        String? @db.Text
  normalizedText String? @db.Text
  textStatus     String?
  textNotes      String?

  sourceChunks SourceChunk[]
  fragments      Fragment[]
}

model Fragment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title            String?
  fragmentType     FragmentType
  /// When set, treated as the primary narrative identity; otherwise `fragmentType` is primary.
  primaryFragmentType FragmentType?
  /// Additional FragmentType values (JSON array of enum strings).
  secondaryFragmentTypes Json?
  surfaceMeaning         String? @db.Text
  hiddenMeaning          String? @db.Text
  symbolicUse            String? @db.Text
  emotionalUse           String? @db.Text
  narrativeUse           String? @db.Text
  /// Cached deterministic or AI-enhanced interpretation summary (author remains source of truth on raw fields).
  generatedInterpretationSummary String? @db.Text
  decompositionPressure  String?
  sceneReadinessScore    Int?
  clusterHint            String?

  visibility       VisibilityStatus @default(PRIVATE)
  recordType       RecordType?
  sourceId         String?
  source           Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceChunkId    String?
  sourceChunk      SourceChunk?     @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)
  sourceTextId     String?
  sourceText       SourceText?      @relation(fields: [sourceTextId], references: [id], onDelete: SetNull)
  parentFragmentId String?
  parentFragment   Fragment?        @relation("FragmentTree", fields: [parentFragmentId], references: [id], onDelete: SetNull)
  childFragments   Fragment[]       @relation("FragmentTree")

  text                 String  @db.Text
  excerpt              String? @db.Text
  summary              String?
  emotionalTone        String?
  narrativeFunction    String?
  timeHint             String?
  confidence           Int?
  ambiguityLevel       Int?
  placementStatus      String?
  reviewStatus         String?
  notes                String?
  decompositionVersion String?
  aiGenerated          Boolean @default(false)
  generatedByRunId     String?
  sourceTraceNote      String?

  placementCandidates FragmentPlacementCandidate[]
  links               FragmentLink[]
  insights            FragmentInsight[]
  brainMemos          BrainMemo[]
  characterMemories   CharacterMemory[]
  clusterLinks        FragmentClusterLink[]

  @@index([fragmentType])
  @@index([sourceId])
  @@index([placementStatus])
  @@index([reviewStatus])
  @@index([parentFragmentId])
  @@index([decompositionPressure])
}

/// Narrative constellation of related fragments (theme, symbol, emotional arc, etc.).
model FragmentCluster {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title             String
  clusterType       String
  summary           String?
  emotionalTone     String?
  dominantFunction  String?
  confidence        Int?
  notes             String?
  /// Cached synthesis (template or AI); author `summary` remains primary record field.
  generatedClusterSynthesis String? @db.Text

  chapterId   String?
  chapter     Chapter?   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  sceneId     String?
  scene       Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  metaSceneId String?
  metaScene   MetaScene? @relation(fields: [metaSceneId], references: [id], onDelete: SetNull)
  personId    String?
  person      Person?    @relation(fields: [personId], references: [id], onDelete: SetNull)
  placeId     String?
  place       Place?     @relation(fields: [placeId], references: [id], onDelete: SetNull)
  symbolId    String?
  symbol      Symbol?    @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  fragmentLinks FragmentClusterLink[]

  @@index([clusterType])
  @@index([chapterId])
  @@index([sceneId])
  @@index([metaSceneId])
  @@index([personId])
  @@index([placeId])
  @@index([symbolId])
}

model FragmentClusterLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId String
  fragment   Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  clusterId  String
  cluster    FragmentCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  role  String?
  notes String?

  @@index([fragmentId])
  @@index([clusterId])
}

/// Reviewable scene-building suggestions from the intelligence engine.
model SceneConstructionSuggestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaSceneId String?
  metaScene   MetaScene? @relation(fields: [metaSceneId], references: [id], onDelete: SetNull)
  sceneId     String?
  scene       Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  title            String
  suggestionType   String
  summary          String  @db.Text
  confidence       Int?
  status           String
  supportingFragmentIds Json?
  notes            String?

  @@index([metaSceneId])
  @@index([sceneId])
  @@index([status])
  @@index([suggestionType])
}

model FragmentPlacementCandidate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId   String
  fragment     Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String?
  targetLabel  String?
  confidence   Int?
  rationale    String?
  status       String
  notes        String?

  @@index([fragmentId])
  @@index([targetType])
  @@index([status])
}

model FragmentLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId String
  fragment   Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  linkedType String
  linkedId   String
  linkRole   String?
  notes      String?

  @@index([fragmentId])
  @@index([linkedType])
}

model FragmentInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId  String
  fragment    Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  insightType String
  content     String   @db.Text
  confidence  Int?
  notes       String?

  @@index([fragmentId])
  @@index([insightType])
}

model BrainMemo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  content  String @db.Text
  memoType String

  linkedSourceId   String?
  linkedSource     Source?   @relation(fields: [linkedSourceId], references: [id], onDelete: SetNull)
  linkedFragmentId String?
  linkedFragment   Fragment? @relation(fields: [linkedFragmentId], references: [id], onDelete: SetNull)
  linkedChapterId  String?
  linkedChapter    Chapter?  @relation(fields: [linkedChapterId], references: [id], onDelete: SetNull)
  linkedSceneId    String?
  linkedScene      Scene?    @relation(fields: [linkedSceneId], references: [id], onDelete: SetNull)

  @@index([memoType])
  @@index([linkedSourceId])
  @@index([linkedFragmentId])
}

model IngestionRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId String
  source   Source @relation("SourceIngestionRuns", fields: [sourceId], references: [id], onDelete: Cascade)

  status        String
  modelName     String?
  promptVersion String?
  runType       String?
  rawTextLength Int?
  tokenEstimate Int?
  notes         String?
  errorMessage  String?
  extractedAt   DateTime?
  reviewedAt    DateTime?

  chunkingMode         String?
  chunkCount           Int?
  aggregatedFromChunks Boolean @default(false)
  aggregationNotes     String?

  lastRunForSource Source? @relation("SourceLastIngestionRun")

  extractionPacket    ExtractionPacket?
  extractionResult    ExtractionResult?
  extractedEntities   ExtractedEntity[]
  chunkExtractionRuns ChunkExtractionRun[]

  @@index([sourceId])
  @@index([status])
}

model ChunkExtractionRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceChunkId String
  sourceChunk   SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)

  ingestionRunId String
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  status          String
  modelName       String?
  promptVersion   String?
  rawTextLength   Int?
  tokenEstimate   Int?
  notes           String?
  errorMessage    String?
  extractedAt     DateTime?
  chunkResultJson Json?
  rawModelOutput  Json?

  @@index([sourceChunkId])
  @@index([ingestionRunId])
  @@index([status])
}

model ExtractionPacket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String       @unique
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  sourceTitle         String
  sourceType          SourceType?
  recordType          RecordType?
  visibility          VisibilityStatus?
  sourceSummary       String?
  sourceNotes         String?
  sourceDate          String?
  sourceYear          Int?
  authorOrOrigin      String?
  rawText             String            @db.Text
  normalizedText      String?           @db.Text
  instructionsVersion String?
  packetJson          Json?
  readyForAI          Boolean           @default(false)

  @@index([sourceId])
}

model ExtractionResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String       @unique
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status          String
  summaryDraft    String?
  peopleDraft     Json?
  placesDraft     Json?
  eventsDraft     Json?
  symbolsDraft    Json?
  claimsDraft     Json?
  chaptersDraft   Json?
  scenesDraft     Json?
  questionsDraft  Json?
  continuityDraft Json?
  resultJson      Json?
  reviewerNotes   String?
  /**
   * Parsed model payload (or wrapper) for debugging normalization issues.
   */
  rawModelOutput  Json?

  @@index([sourceId])
  @@index([status])
}

model ExtractedEntity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  entityType        String
  proposedName      String?
  proposedTitle     String?
  proposedData      Json?
  confidence        Int?
  reviewStatus      String
  /**
   * Legacy link fields used by existing UI/actions.
   * Kept for backward compatibility; newer linking uses canonicalRecord* below.
   */
  matchedRecordId   String?
  matchedRecordType String?
  reviewerNotes     String?

  /**
   * Phase 5A merge/link tracking. These fields record exactly what happened
   * to each extracted row during human review.
   */
  matchMethod         String? // manual_exact, manual_selected, heuristic_name, heuristic_title, promoted_new
  mergeDecision       String? // none, linked_only, merged_into_existing, promoted_new, rejected
  mergeSnapshot       Json? // what fields were merged / chosen
  reviewedByNote      String?
  canonicalRecordId   String?
  canonicalRecordType String?

  links EntityLink[]

  @@index([sourceId])
  @@index([ingestionRunId])
  @@index([entityType])
  @@index([reviewStatus])
  @@index([canonicalRecordType, canonicalRecordId])
  @@index([mergeDecision])
}

model EntityLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extractedEntityId String
  extractedEntity   ExtractedEntity @relation(fields: [extractedEntityId], references: [id], onDelete: Cascade)

  canonicalEntityType String
  canonicalEntityId   String
  linkType            String // matched, linked_only, merged_into, promoted_new
  confidence          Int?
  notes               String?

  @@index([extractedEntityId])
  @@index([canonicalEntityType, canonicalEntityId])
  @@index([linkType])
}

model Alias {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label      String
  aliasType  String? // alternate_name, spelling_variant, nickname, title_variant
  entityType String // person, place, event, symbol, chapter
  entityId   String
  notes      String?

  @@index([entityType, entityId])
  @@index([label])
}

/// Logical slot: one stable ãquestionã (e.g. ãfather of Xã). Competing assertions reference the same slot.
model GenealogicalFactSlot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subjectType String
  subjectId   String
  predicate   GenealogicalPredicate
  /// Disambiguate multiple slots for the same predicate (e.g. census year, oral vs record).
  discriminator String @default("")

  slotLabel String?
  notes     String?  @db.Text

  assertions GenealogicalAssertion[]

  @@unique([subjectType, subjectId, predicate, discriminator])
  @@index([subjectType, subjectId])
}

/// One cited (or invented-branch) statement in a slot. Many ACTIVE rows = competing claims; `narrativePreferred` picks prose default without deleting others.
model GenealogicalAssertion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slotId String
  slot   GenealogicalFactSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  valueJson Json

  visibility   VisibilityStatus
  recordType   RecordType
  confidence   Int              @default(3)
  quoteExcerpt String?          @db.Text
  notes        String?          @db.Text
  needsReview  Boolean          @default(true)

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  status FactAssertionStatus @default(ACTIVE)

  /// If this assertion supersedes another row (audit); does not remove competing branches unless REJECTED.
  supersedesId String?
