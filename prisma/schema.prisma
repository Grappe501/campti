  layers    Json?

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  scenes             Scene[]
  fragmentClusters   FragmentCluster[]

  @@index([sourceId])
}

/// Atomic narrative logic extracted from documents (editable; strength guides generation).
model NarrativeRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String @db.Text

  category String // structure, character, memory, symbolism, relationship, narration
  strength Int? // 1–5
  scope    String? // global, scene, character, lineage

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  notes  String?
  layers Json?

  @@index([sourceId])
  @@index([category])
}

model Theme {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String @db.Text

  intensity Int? // 1–5
  category  String? // core, subtheme

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  notes  String?
  layers Json?

  @@index([sourceId])
}

model Motif {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String @db.Text
  /// Stage 2+: motif categories may align with RegistryValue (family SYMBOLIC); free text until migration.
  usagePattern String?

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  notes  String?
  layers Json?

  @@index([sourceId])
}

model LiteraryDevice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  description   String @db.Text
  systemEffect  String @db.Text

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  notes  String?
  layers Json?

  @@index([sourceId])
}

model NarrativePattern {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String @db.Text

  patternType String // generational, emotional, relational, identity
  strength    Int?

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  notes  String?
  layers Json?

  @@index([sourceId])
  @@index([patternType])
}

/// Polymorphic cross-links between narrative DNA entities and world-model objects.
model NarrativeBinding {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceType   String
  sourceId     String
  targetType   String
  targetId     String
  relationship String // influences, expresses, contradicts, emerges_from

  strength Int?
  notes    String?

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relationship])
}

model OpenQuestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title           String
  description     String?
  status          String
  priority        Int?
  sourceTraceNote String?

  linkedPersonId String?
  linkedPerson   Person? @relation(fields: [linkedPersonId], references: [id], onDelete: SetNull)
  linkedPlaceId  String?
  linkedPlace    Place?  @relation(fields: [linkedPlaceId], references: [id], onDelete: SetNull)
  linkedEventId  String?
  linkedEvent    Event?  @relation(fields: [linkedEventId], references: [id], onDelete: SetNull)
  linkedSourceId String?
  linkedSource   Source? @relation(fields: [linkedSourceId], references: [id], onDelete: SetNull)

  scenes Scene[]

  @@index([status])
  @@index([priority])
}

model ContinuityNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title           String
  description     String?
  severity        String
  status          String
  sourceTraceNote String?

  linkedChapterId String?
  linkedChapter   Chapter? @relation(fields: [linkedChapterId], references: [id], onDelete: SetNull)
  linkedSceneId   String?
  linkedScene     Scene?   @relation(fields: [linkedSceneId], references: [id], onDelete: SetNull)
  linkedPersonId  String?
  linkedPerson    Person?  @relation(fields: [linkedPersonId], references: [id], onDelete: SetNull)
  linkedEventId   String?
  linkedEvent     Event?   @relation(fields: [linkedEventId], references: [id], onDelete: SetNull)

  @@index([severity])
  @@index([status])
}

model SceneNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sceneId String
  scene   Scene  @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  noteType String
  content  String @db.Text

  @@index([sceneId])
  @@index([noteType])
}

/// Last mode in public reader: Read / Feel / Guided / Listen (maps to UI labels).
enum ReaderLastMode {
  reading
  immersive
  guided
  listen
}

enum ReaderImprintEntityType {
  scene
  character
  place
  symbol
  chapter
  audio
}

enum ReaderImprintKind {
  lingered
  revisited
  paused
  replayed
  completed
  emotional_peak
  listened
  returned
  expanded_depth
}

/// Per-browser (or logged-in user) reading cursor + soft emotional memory.
model ReaderState {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  sessionId String @unique

  lastSceneId     String?
  lastMetaSceneId String?
  lastCharacterId String?
  lastPlaceId     String?
  lastSymbolId    String?

  lastMode         ReaderLastMode?
  emotionalTrace   String?
  returnHook       String?
  /** Author- or server-composed invitation to continue the narrative thread. */
  continuationHeadline String?
  /** Opaque client key for scroll/segment resume (e.g. hash of scene + segment). */
  lastScrollKey  String?
  lastInteractionAt DateTime @default(now())
  notes          String?

  /// Client-restored scroll anchor (main column).
  scrollAnchorY Int?
  /// Guided / immersive rhythm: true = follow perception cadence when available.
  rhythmAuto    Boolean? @default(true)

  threads ReaderThread[]

  @@index([userId])
  @@index([lastInteractionAt])
}

/// What the reader lingered on — not just clicks.
model ReaderImprint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  userId    String?

  entityType  ReaderImprintEntityType
  entityId    String
  imprintType ReaderImprintKind
  weight      Int
  notes       String?

  @@index([sessionId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([imprintType])
}

/// Optional persisted thread anchors (derived rows may also exist only in app logic).
model ReaderThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  sessionId String?

  threadType       String
  anchorEntityType String?
  anchorEntityId   String?
  label            String
  strength         Int?
  isActive         Boolean @default(true)
  notes            String?

  readerStateId String?
  readerState   ReaderState? @relation(fields: [readerStateId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@index([threadType])
  @@index([isActive])
}

/// Listening time toward a character (attachment signal for audio / premium hooks).
model ReaderVoiceListen {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  userId    String?
  personId  String

  totalListenSeconds Int      @default(0)
  lastListenAt       DateTime @default(now())

  @@unique([sessionId, personId])
  @@index([personId])
  @@index([totalListenSeconds])
}

/// System governing law for deterministic simulation (Stage 1). Distinct from `NarrativeRule` (source-extracted DNA).
/// Policy “kinds” (Truth, Voice, Determinism, …) are expressed via `ruleType`, not separate Prisma models.
model ConstitutionalRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key         String   @unique
  name        String
  description String   @db.Text

  ruleType RuleType
  scope    RuleScope
  severity RuleSeverity

  isActive Boolean @default(true)

  recordType RecordType
  visibility VisibilityStatus

  /// Certainty / confidence label for this rule as an object (e.g. system, contested).
  certainty String?

  /// Aligns with `NarrativePermissionProfile.key` / RegistryValue (family PERMISSION) when set.
  narrativePermission String?

  /// Rule-specific structured parameters for enforcement engines (Stage 14+).
  /// May reference OntologyType.key or RegistryValue.key as strings; keep keys stable for forward compatibility.
  config Json?
  notes  String? @db.Text

  @@index([ruleType])
  @@index([scope])
  @@index([severity])
  @@index([isActive])
  @@index([recordType])
  @@index([visibility])
}

/// Master registry: kinds of objects that may exist in Campti (person, scene, branch_condition, …).
model OntologyType {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key         String         @unique
  name        String
  description String         @db.Text
  family      OntologyFamily
  isActive    Boolean        @default(true)
  recordType  RecordType
  visibility  VisibilityStatus

  appliesTo       Json?
  sourceTraceNote String? @db.Text
  notes           String? @db.Text

  @@index([family])
  @@index([isActive])
  @@index([recordType])
  @@index([visibility])
}

/// Editable controlled vocabulary (categories, permissions, readiness, branch states, …).
model RegistryValue {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key          String         @unique
  label        String
  description  String?        @db.Text
  registryType String         @default("default")
  family       RegistryFamily
  sortOrder    Int            @default(0)
  isActive     Boolean        @default(true)

  config Json?
  /// Future: scope targets (e.g. model names) without join tables yet.
  appliesTo       Json?
  sourceTraceNote String? @db.Text
  notes           String? @db.Text

  @@index([family])
  @@index([registryType])
  @@index([isActive])
  @@index([sortOrder])
}

/// Narrative permission ladder — what information may do in story systems (bindings, drafts, reveal).
model NarrativePermissionProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key         String  @unique
  name        String
  description String? @db.Text
  isActive    Boolean @default(true)

  allowsDirectNarrativeUse Boolean @default(false)
  allowsSceneSupport        Boolean @default(false)
  allowsAtmosphereSupport   Boolean @default(false)
  allowsCanonicalReveal     Boolean @default(false)

  recordType RecordType       @default(HYBRID)
  visibility VisibilityStatus @default(REVIEW)

  notes String? @db.Text

  @@index([isActive])
}

/// Standardized confidence ladder (maps to numeric rank for ordering).
model ConfidenceProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key          String @unique
  label        String
  description  String? @db.Text
  numericValue Int

  isActive Boolean @default(true)

  recordType RecordType       @default(HYBRID)
  visibility VisibilityStatus @default(REVIEW)

  notes String? @db.Text

  @@index([numericValue])
  @@index([isActive])
}

/// Scene composition readiness gates (draft eligibility spine).
model SceneReadinessProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key         String  @unique
  label       String
  description String? @db.Text
  isDraftable Boolean @default(false)

  isActive Boolean @default(true)

  recordType RecordType       @default(HYBRID)
  visibility VisibilityStatus @default(REVIEW)

  notes String? @db.Text

  @@index([isActive])
}
