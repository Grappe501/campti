  /// Exactly one preferred assertion per slot for generation / default UI (enforced in application transactions).
  narrativePreferred Boolean @default(false)

  /// Optional parallel narrative branch tag when multiple ACTIVE claims intentionally coexist (e.g. reconstruction forks).
  branchTag String?

  @@index([slotId])
  @@index([sourceId])
  @@index([status])
  @@index([legacyClaimId])
}

