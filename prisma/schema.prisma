/// Scene composition readiness gates (draft eligibility spine).
model SceneReadinessProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key         String  @unique
  label       String
  description String? @db.Text
  isDraftable Boolean @default(false)

  isActive Boolean @default(true)

