model SceneNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sceneId String
  scene   Scene  @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  noteType String
  content  String @db.Text

  @@index([sceneId])
  @@index([noteType])
}

/// Last mode in public reader: Read / Feel / Guided / Listen (maps to UI labels).
enum ReaderLastMode {
  reading
  immersive
  guided
  listen
}

enum ReaderImprintEntityType {
  scene
  character
  place
  symbol
  chapter
  audio
}

enum ReaderImprintKind {
  lingered
  revisited
  paused
  replayed
  completed
  emotional_peak
  listened
  returned
  expanded_depth
}

/// Per-browser (or logged-in user) reading cursor + soft emotional memory.
model ReaderState {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  sessionId String @unique

  lastSceneId     String?
  lastMetaSceneId String?
  lastCharacterId String?
  lastPlaceId     String?
  lastSymbolId    String?

  lastMode         ReaderLastMode?
  emotionalTrace   String?
  returnHook       String?
  /** Author- or server-composed invitation to continue the narrative thread. */
  continuationHeadline String?
  /** Opaque client key for scroll/segment resume (e.g. hash of scene + segment). */
  lastScrollKey  String?
  lastInteractionAt DateTime @default(now())
  notes          String?

  /// Client-restored scroll anchor (main column).
  scrollAnchorY Int?
  /// Guided / immersive rhythm: true = follow perception cadence when available.
  rhythmAuto    Boolean? @default(true)

  threads ReaderThread[]

  @@index([userId])
  @@index([lastInteractionAt])
}

/// What the reader lingered on — not just clicks.
model ReaderImprint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  userId    String?

  entityType  ReaderImprintEntityType
  entityId    String
  imprintType ReaderImprintKind
  weight      Int
  notes       String?

  @@index([sessionId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([imprintType])
}

/// Optional persisted thread anchors (derived rows may also exist only in app logic).
model ReaderThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?
  sessionId String?

  threadType       String
  anchorEntityType String?
  anchorEntityId   String?
  label            String
  strength         Int?
  isActive         Boolean @default(true)
  notes            String?

  readerStateId String?
  readerState   ReaderState? @relation(fields: [readerStateId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([userId])
  @@index([threadType])
  @@index([isActive])
}

/// Listening time toward a character (attachment signal for audio / premium hooks).
model ReaderVoiceListen {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessionId String
  userId    String?
  personId  String

  totalListenSeconds Int      @default(0)
  lastListenAt       DateTime @default(now())

  @@unique([sessionId, personId])
  @@index([personId])
  @@index([totalListenSeconds])
}
