/// Louisiana colony census OCR bundle (imported from `campti_census.sqlite` for simulation / queries).
model CensusResearchDataset {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label            String
  notes            String? @db.Text
  sqliteOriginPath String?

  /// Short catalog blurb for LLM / story-assembly prompt injection (stable summary of this bundle).
  storyAssemblySummary String? @db.Text

  /// Optional link to the script-indexed `Source` row for the `.sqlite` file (upload-* id).
  linkedSourceId String?
  linkedSource   Source? @relation(fields: [linkedSourceId], references: [id], onDelete: SetNull)

  pages        CensusResearchPage[]
  entries      CensusResearchEntry[]
  nameRows     CensusResearchNameRow[]
  missingPages CensusResearchMissingPage[]

  @@index([linkedSourceId])
}

model CensusResearchPage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasetId String
  dataset   CensusResearchDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  /// `pages.order` in the source SQLite export.
  sortOrder   Int
  filename    String
  pagerRaw    String?
  cleanLen    Int?
  textHash    String?
  textPreview String? @db.Text
  ocrText     String? @db.Text
  pageType    String?
  docPageCode String?
  isDuplicate Boolean @default(false)
  titleGuess  String?

  /// Uppercase ASCII-ish fold of title_guess for matching (optional; filled on import).
  normalizedTitleGuess String @default("")

  @@unique([datasetId, sortOrder])
  @@index([datasetId])
  @@index([filename])
  @@index([docPageCode])
  @@index([normalizedTitleGuess])
}

model CensusResearchEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasetId String
  dataset   CensusResearchDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  /// `entry_id` in the source SQLite export.
  externalEntryId Int

  sourceFilename   String
  sourceOrder      Int?
  docPageCode      String?
  pageType         String?
  rawEntry         String  @db.Text
  displayName      String?
  childrenCount     Float?
  negroSlavesCount  Float?
  indianSlavesCount Float?
  domesticCount     Float?
  wifeMentioned     Boolean @default(false)
  widowMentioned    Boolean @default(false)
  onHisLand         Boolean @default(false)
  roleGuess         String?

  /// Denormalized label for search + AI: from name_index.normalized_name when present, else derived from display_name.
  normalizedLabel String @default("")

  @@unique([datasetId, externalEntryId])
  @@index([datasetId])
  @@index([displayName])
  @@index([docPageCode])
  @@index([normalizedLabel])
}

model CensusResearchNameRow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasetId String
  dataset   CensusResearchDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  externalEntryId Int?
  displayName     String
  normalizedName  String
  sourceFilename  String?
  docPageCode     String?

  @@index([datasetId])
  @@index([normalizedName])
}

model CensusResearchMissingPage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  datasetId String
  dataset   CensusResearchDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  missingGroupId   String
  status           String?
  description      String? @db.Text
  insertAfterOrder Int?
  expectedSource   String? @db.Text
  notes            String? @db.Text

  @@unique([datasetId, missingGroupId])
}

/// Directed edge: narrative consumer (scene, chapter, ãÎ) depends on a producer entity for revision invalidation.
/// Producer identity is (producerKind + producerId); no polymorphic FK to keep migrations stable.
model NarrativeDependencyEdge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  consumerKind NarrativeDependencyConsumerKind
  consumerId   String

  producerKind NarrativeDependencyProducerKind
  producerId   String

  strength DependencyStrength @default(HARD)

  /// Optional fingerprint of the consumer input bundle when the edge was written (e.g. hash of SceneAssistRun inputSnapshot).
  inputSnapshotHash String?

  @@index([consumerKind, consumerId])
  @@index([producerKind, producerId])
  @@index([strength])
}

/// Durable queue row for regeneration / continuity passes after upstream fact changes.
model RevisionJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kind   RevisionJobKind
  status RevisionJobStatus @default(PENDING)

  /// Primary target when kind is scene-scoped.
  sceneId String?
  scene   Scene?  @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  payload       Json?
  errorMessage  String?   @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  attemptCount  Int       @default(0)

  @@index([status])
  @@index([kind])
  @@index([sceneId])
}
