generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VisibilityStatus {
  PRIVATE @map("private")
  REVIEW  @map("review")
  PUBLIC  @map("public")
}

enum RecordType {
  HISTORICAL   @map("historical")
  ORAL_HISTORY @map("oral_history")
  INFERRED     @map("inferred")
  FICTIONAL    @map("fictional")
  HYBRID       @map("hybrid")
}

enum SourceType {
  PDF   @map("pdf")
  DOCX  @map("doc")
  NOTE  @map("note")
  IMAGE @map("image")
  AUDIO @map("audio")
  VIDEO @map("video")
  WEB   @map("web")
  OTHER @map("source_other")
}

enum PlaceType {
  TOWN     @map("town")
  LAKE     @map("lake")
  CHURCH   @map("church")
  REGION   @map("region")
  CEMETERY @map("cemetery")
  HOME     @map("home")
  FIELD    @map("field")
  RIVER    @map("river")
  OTHER    @map("place_other")
}

enum EventType {
  BIRTH     @map("birth")
  DEATH     @map("death")
  MARRIAGE  @map("marriage")
  MIGRATION @map("migration")
  LAND      @map("land")
  CHURCH    @map("church_event")
  WAR       @map("war")
  FAMILY    @map("family")
  POLITICAL @map("political")
  CULTURAL  @map("cultural")
  OTHER     @map("event_other")
}

enum SymbolCategory {
  ELEMENTAL @map("element")
  CULINARY  @map("food")
  LANDSCAPE @map("plant")
  RELIGIOUS @map("religious")
  FAMILY    @map("family_sym")
  RITUAL    @map("ritual")
  OTHER     @map("symbol_other")
}

enum WritingMode {
  STRUCTURED
  NARRATIVE
  HYBRID
}

/// Story-system personality law (default; author may override in CharacterProfile fields).
enum EnneagramType {
  ONE
  TWO
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
}

enum FragmentType {
  CREATIVE_FRAGMENT
  SCENE_SEED
  CHAPTER_SEED
  MEMORY
  EMOTIONAL_BEAT
  CHARACTER_INSIGHT
  SYMBOLIC_NOTE
  MOTIF_RULE
  STRUCTURAL_OUTLINE
  HISTORICAL_ANCHOR
  ORAL_HISTORY
  RESEARCH_NOTE
  NARRATOR_VOICE
  CONTINUITY_CONSTRAINT
  QUESTION_SEED
  THEME_STATEMENT
  IMAGE_OR_SENSORY
  DIALOGUE_SNIPPET
  OTHER
}

/// Constitutional / simulation law category (TruthPolicy, VoicePolicy, etc. are rows with this type — not separate tables).
enum RuleType {
  TRUTH
  AMBIGUITY
  REVEAL
  VOICE
  VIOLENCE
  THEOLOGY
  DETERMINISM
  DRAFT_ELIGIBILITY
}

enum RuleScope {
  GLOBAL
  ENTITY
  SCENE
  CHARACTER
  VOICE
  SYSTEM
}

enum RuleSeverity {
  INFO
  WARNING
  BLOCKING
}

/// Character engine — bounded choice and moral/social limits.
enum CharacterConstraintType {
  MORAL
  SOCIAL
  PHYSICAL
  PSYCHOLOGICAL
}

/// Character engine — what activates interior response.
enum CharacterTriggerType {
  EMOTIONAL
  SOCIAL
  MEMORY
  ENVIRONMENTAL
}

/// Environment & risk layer — reusable categories for RiskRegime and analytics.
enum EnvironmentRiskCategory {
  FLOOD
  DISEASE
  CONFLICT
  ISOLATION
  SCARCITY
  SURVEILLANCE
  TRANSPORT
}

/// Corridor / adjacency between simulation nodes (river, trail, trade path, etc.).
enum NodeConnectionType {
  RIVER
  BAYOU
  TRAIL
  ROAD
  FERRY
  MILITARY_ROUTE
  TRADE_PATH
}

/// Layered meaning attached to a place (sacred, trauma, trade, etc.).
enum PlaceMemoryType {
  SACRED
  TRAUMA
  BURIAL
  TRADE
  WAR
  COMMUNITY
  DISPLACEMENT
  CONTINUITY
}

/// Stage 2 — Ontology spine: what classes of objects exist in the simulation graph.
enum OntologyFamily {
  ENTITY
  NARRATIVE
  SIMULATION
  ENVIRONMENT
  RELATIONSHIP
  SUPPORT
}

/// Stage 2 — Controlled vocabulary families for RegistryValue rows.
enum RegistryFamily {
  SYMBOLIC
  RELATIONSHIP
  ENVIRONMENT
  PRESSURE
  PERMISSION
  READINESS
  BRANCH
  GENERAL
}

model Source {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility       VisibilityStatus
  recordType       RecordType
  title            String
  sourceType       SourceType       @map("type")
  filePath         String?
  summary          String?
  originalFilename String?
  notes            String?
  sourceDate       String?
  sourceYear       Int?
  authorOrOrigin   String?
  archiveStatus    String?
  ingestionReady   Boolean          @default(false)

  ingestionStatus    String?
  lastIngestionRunId String? @unique
  processingNotes    String?
  extractedSummary   String?
  reviewedSummary    String?

  claims        Claim[]
  persons       Person[]
  places        Place[]
  events        Event[]
  chapters      Chapter[]
  scenes        Scene[]
  openQuestions OpenQuestion[]

  sourceText        SourceText?
  ingestionRuns     IngestionRun[]     @relation("SourceIngestionRuns")
  lastIngestionRun  IngestionRun?      @relation("SourceLastIngestionRun", fields: [lastIngestionRunId], references: [id], onDelete: SetNull)
  extractionPackets ExtractionPacket[]
  extractionResults ExtractionResult[]
  extractedEntities ExtractedEntity[]
  sourceChunks      SourceChunk[]
  fragments         Fragment[]
  brainMemos        BrainMemo[]

  narrativeRules      NarrativeRule[]
  narrativeThemes     Theme[]
  motifs              Motif[]
  literaryDevices     LiteraryDevice[]
  narrativePatterns   NarrativePattern[]
  narrativeDnaSymbols Symbol[]

  @@index([visibility])
  @@index([recordType])
  @@index([sourceType])
  @@index([ingestionStatus])
  @@index([archiveStatus])
}

model SourceChunk {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  sourceTextId String?
  sourceText   SourceText? @relation(fields: [sourceTextId], references: [id], onDelete: SetNull)

  chunkIndex     Int
  startOffset    Int?
  endOffset      Int?
  charCount      Int?
  tokenEstimate  Int?
  headingHint    String?
  chunkLabel     String?
  rawText        String? @db.Text
  normalizedText String? @db.Text
  textStatus     String?
  notes          String?

  chunkExtractionRuns ChunkExtractionRun[]
  fragments           Fragment[]

  @@index([sourceId])
  @@index([chunkIndex])
}

model SourceText {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId       String  @unique
  source         Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawText        String? @db.Text
  normalizedText String? @db.Text
  textStatus     String?
  textNotes      String?

  sourceChunks SourceChunk[]
  fragments      Fragment[]
}

model Fragment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title            String?
  fragmentType     FragmentType
  /// When set, treated as the primary narrative identity; otherwise `fragmentType` is primary.
  primaryFragmentType FragmentType?
  /// Additional FragmentType values (JSON array of enum strings).
  secondaryFragmentTypes Json?
  surfaceMeaning         String? @db.Text
  hiddenMeaning          String? @db.Text
  symbolicUse            String? @db.Text
  emotionalUse           String? @db.Text
  narrativeUse           String? @db.Text
  /// Cached deterministic or AI-enhanced interpretation summary (author remains source of truth on raw fields).
  generatedInterpretationSummary String? @db.Text
  decompositionPressure  String?
  sceneReadinessScore    Int?
  clusterHint            String?

  visibility       VisibilityStatus @default(PRIVATE)
  recordType       RecordType?
  sourceId         String?
  source           Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceChunkId    String?
  sourceChunk      SourceChunk?     @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)
  sourceTextId     String?
  sourceText       SourceText?      @relation(fields: [sourceTextId], references: [id], onDelete: SetNull)
  parentFragmentId String?
  parentFragment   Fragment?        @relation("FragmentTree", fields: [parentFragmentId], references: [id], onDelete: SetNull)
  childFragments   Fragment[]       @relation("FragmentTree")

  text                 String  @db.Text
  excerpt              String? @db.Text
  summary              String?
  emotionalTone        String?
  narrativeFunction    String?
  timeHint             String?
  confidence           Int?
  ambiguityLevel       Int?
  placementStatus      String?
  reviewStatus         String?
  notes                String?
  decompositionVersion String?
  aiGenerated          Boolean @default(false)
  generatedByRunId     String?
  sourceTraceNote      String?

  placementCandidates FragmentPlacementCandidate[]
  links               FragmentLink[]
  insights            FragmentInsight[]
  brainMemos          BrainMemo[]
  characterMemories   CharacterMemory[]
  clusterLinks        FragmentClusterLink[]

  @@index([fragmentType])
  @@index([sourceId])
  @@index([placementStatus])
  @@index([reviewStatus])
  @@index([parentFragmentId])
  @@index([decompositionPressure])
}

/// Narrative constellation of related fragments (theme, symbol, emotional arc, etc.).
model FragmentCluster {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title             String
  clusterType       String
  summary           String?
  emotionalTone     String?
  dominantFunction  String?
  confidence        Int?
  notes             String?
  /// Cached synthesis (template or AI); author `summary` remains primary record field.
  generatedClusterSynthesis String? @db.Text

  chapterId   String?
  chapter     Chapter?   @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  sceneId     String?
  scene       Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  metaSceneId String?
  metaScene   MetaScene? @relation(fields: [metaSceneId], references: [id], onDelete: SetNull)
  personId    String?
  person      Person?    @relation(fields: [personId], references: [id], onDelete: SetNull)
  placeId     String?
  place       Place?     @relation(fields: [placeId], references: [id], onDelete: SetNull)
  symbolId    String?
  symbol      Symbol?    @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  fragmentLinks FragmentClusterLink[]

  @@index([clusterType])
  @@index([chapterId])
  @@index([sceneId])
  @@index([metaSceneId])
  @@index([personId])
  @@index([placeId])
  @@index([symbolId])
}

model FragmentClusterLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId String
  fragment   Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  clusterId  String
  cluster    FragmentCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  role  String?
  notes String?

  @@index([fragmentId])
  @@index([clusterId])
}

/// Reviewable scene-building suggestions from the intelligence engine.
model SceneConstructionSuggestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaSceneId String?
  metaScene   MetaScene? @relation(fields: [metaSceneId], references: [id], onDelete: SetNull)
  sceneId     String?
  scene       Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  title            String
  suggestionType   String
  summary          String  @db.Text
  confidence       Int?
  status           String
  supportingFragmentIds Json?
  notes            String?

  @@index([metaSceneId])
  @@index([sceneId])
  @@index([status])
  @@index([suggestionType])
}

model FragmentPlacementCandidate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId   String
  fragment     Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String?
  targetLabel  String?
  confidence   Int?
  rationale    String?
  status       String
  notes        String?

  @@index([fragmentId])
  @@index([targetType])
  @@index([status])
}

model FragmentLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId String
  fragment   Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  linkedType String
  linkedId   String
  linkRole   String?
  notes      String?

  @@index([fragmentId])
  @@index([linkedType])
}

model FragmentInsight {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fragmentId  String
  fragment    Fragment @relation(fields: [fragmentId], references: [id], onDelete: Cascade)
  insightType String
  content     String   @db.Text
  confidence  Int?
  notes       String?

  @@index([fragmentId])
  @@index([insightType])
}

model BrainMemo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  content  String @db.Text
  memoType String

  linkedSourceId   String?
  linkedSource     Source?   @relation(fields: [linkedSourceId], references: [id], onDelete: SetNull)
  linkedFragmentId String?
  linkedFragment   Fragment? @relation(fields: [linkedFragmentId], references: [id], onDelete: SetNull)
  linkedChapterId  String?
  linkedChapter    Chapter?  @relation(fields: [linkedChapterId], references: [id], onDelete: SetNull)
  linkedSceneId    String?
  linkedScene      Scene?    @relation(fields: [linkedSceneId], references: [id], onDelete: SetNull)

  @@index([memoType])
  @@index([linkedSourceId])
  @@index([linkedFragmentId])
}

model IngestionRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceId String
  source   Source @relation("SourceIngestionRuns", fields: [sourceId], references: [id], onDelete: Cascade)

  status        String
  modelName     String?
  promptVersion String?
  runType       String?
  rawTextLength Int?
  tokenEstimate Int?
  notes         String?
  errorMessage  String?
  extractedAt   DateTime?
  reviewedAt    DateTime?

  chunkingMode         String?
  chunkCount           Int?
  aggregatedFromChunks Boolean @default(false)
  aggregationNotes     String?

  lastRunForSource Source? @relation("SourceLastIngestionRun")

  extractionPacket    ExtractionPacket?
  extractionResult    ExtractionResult?
  extractedEntities   ExtractedEntity[]
  chunkExtractionRuns ChunkExtractionRun[]

  @@index([sourceId])
  @@index([status])
}

model ChunkExtractionRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceChunkId String
  sourceChunk   SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)

  ingestionRunId String
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  status          String
  modelName       String?
  promptVersion   String?
  rawTextLength   Int?
  tokenEstimate   Int?
  notes           String?
  errorMessage    String?
  extractedAt     DateTime?
  chunkResultJson Json?
  rawModelOutput  Json?

  @@index([sourceChunkId])
  @@index([ingestionRunId])
  @@index([status])
}

model ExtractionPacket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String       @unique
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  sourceTitle         String
  sourceType          SourceType?
  recordType          RecordType?
  visibility          VisibilityStatus?
  sourceSummary       String?
  sourceNotes         String?
  sourceDate          String?
  sourceYear          Int?
  authorOrOrigin      String?
  rawText             String            @db.Text
  normalizedText      String?           @db.Text
  instructionsVersion String?
  packetJson          Json?
  readyForAI          Boolean           @default(false)

  @@index([sourceId])
}

model ExtractionResult {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String       @unique
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status          String
  summaryDraft    String?
  peopleDraft     Json?
  placesDraft     Json?
  eventsDraft     Json?
  symbolsDraft    Json?
  claimsDraft     Json?
  chaptersDraft   Json?
  scenesDraft     Json?
  questionsDraft  Json?
  continuityDraft Json?
  resultJson      Json?
  reviewerNotes   String?
  /**
   * Parsed model payload (or wrapper) for debugging normalization issues.
   */
  rawModelOutput  Json?

  @@index([sourceId])
  @@index([status])
}

model ExtractedEntity {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingestionRunId String
  ingestionRun   IngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  entityType        String
  proposedName      String?
  proposedTitle     String?
  proposedData      Json?
  confidence        Int?
  reviewStatus      String
  /**
   * Legacy link fields used by existing UI/actions.
   * Kept for backward compatibility; newer linking uses canonicalRecord* below.
   */
  matchedRecordId   String?
  matchedRecordType String?
  reviewerNotes     String?

  /**
   * Phase 5A merge/link tracking. These fields record exactly what happened
   * to each extracted row during human review.
   */
  matchMethod         String? // manual_exact, manual_selected, heuristic_name, heuristic_title, promoted_new
  mergeDecision       String? // none, linked_only, merged_into_existing, promoted_new, rejected
  mergeSnapshot       Json? // what fields were merged / chosen
  reviewedByNote      String?
  canonicalRecordId   String?
  canonicalRecordType String?

  links EntityLink[]

  @@index([sourceId])
  @@index([ingestionRunId])
  @@index([entityType])
  @@index([reviewStatus])
  @@index([canonicalRecordType, canonicalRecordId])
  @@index([mergeDecision])
}

model EntityLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extractedEntityId String
  extractedEntity   ExtractedEntity @relation(fields: [extractedEntityId], references: [id], onDelete: Cascade)

  canonicalEntityType String
  canonicalEntityId   String
  linkType            String // matched, linked_only, merged_into, promoted_new
  confidence          Int?
  notes               String?

  @@index([extractedEntityId])
  @@index([canonicalEntityType, canonicalEntityId])
  @@index([linkType])
}

model Alias {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label      String
  aliasType  String? // alternate_name, spelling_variant, nickname, title_variant
  entityType String // person, place, event, symbol, chapter
  entityId   String
  notes      String?

  @@index([entityType, entityId])
  @@index([label])
}

model Claim {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility   VisibilityStatus
  recordType   RecordType
  description  String
  confidence   Int              @default(3)
  quoteExcerpt String?
  notes        String?
  needsReview  Boolean          @default(true)

  sourceId String
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([needsReview])
  @@index([confidence])
}

/// Stable identity row; simulation layers hang off this. OntologyType key `person` classifies instances (see OntologyType seed).
model Person {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility      VisibilityStatus
  recordType      RecordType
  name            String
  description     String?
  enneagram       Int?
  birthYear       Int?
  deathYear       Int?
  sourceTraceNote String?

  places          Place[]
  events          Event[]
  chapters        Chapter[]
  scenes          Scene[]
  sources         Source[]
  openQuestions   OpenQuestion[]
  continuityNotes ContinuityNote[]

  characterProfile  CharacterProfile?
  characterMemories CharacterMemory[]
  characterStates   CharacterState[]
  metaScenesAsPov   MetaScene[]
  fragmentClusters    FragmentCluster[]
  relationshipsAsA   CharacterRelationship[] @relation("CharacterRelationshipPersonA")
  relationshipsAsB   CharacterRelationship[] @relation("CharacterRelationshipPersonB")
  voicePasses        VoicePass[]
  characterVoiceAssets CharacterVoiceAsset[]

  characterConstraints        CharacterConstraint[]
  characterTriggers           CharacterTrigger[]
  characterPerceptionProfile CharacterPerceptionProfile?
  characterVoiceProfile      CharacterVoiceProfile?
  characterChoiceProfile     CharacterChoiceProfile?
}

/// Pointer to external / master timeline world-state definitions (era slice). Not full simulation logic.
model WorldStateReference {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eraId       String   @unique
  label       String
  description String?  @db.Text

  recordType RecordType       @default(HYBRID)
  visibility VisibilityStatus @default(REVIEW)
  certainty  String?

  characterStates CharacterState[]
  placeStates     PlaceState[]
  nodeConnections NodeConnection[]
  placeMemories   PlaceMemoryProfile[]

  @@index([eraId])
}

model Place {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility      VisibilityStatus
  recordType      RecordType
  name            String
  description     String?
  placeType       PlaceType        @map("type")
  latitude        Float?
  longitude       Float?
  sourceTraceNote String?

  /// Sacred-place / emotional return phrase for readers (optional author line).
  publicReturnPhrase String?

  persons       Person[]
  chapters      Chapter[]
  events        Event[]
  scenes        Scene[]
  sources       Source[]
  openQuestions OpenQuestion[]

  settingProfile SettingProfile?
  settingStates  SettingState[]
  metaScenes     MetaScene[]
  fragmentClusters FragmentCluster[]

  /// Simulation layer — persistent terrain / hydrology / resource logic (Environment & Node Engine).
  environmentProfile  PlaceEnvironmentProfile?
  placeStates         PlaceState[]
  environmentNodes    EnvironmentNode[]
  placeMemoryProfiles PlaceMemoryProfile[]

  @@index([visibility])
  @@index([placeType])
}

/// First-class narrative voice behavior (scope = narrator, character, scene mode, etc.).
model NarrativeVoiceProfile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  scopeType String // narrator, character, scene_mode, lineage, place, custom
  scopeId   String? // personId, metaSceneId, etc.

  voiceLabel        String?
  sentenceRhythm    String?
  dictionStyle      String?
  emotionalRegister String?
  metaphorDensity   String?
  sensoryBias       String?
  interiorityStyle  String?
  silenceStyle      String?
  memoryStyle       String?
  spiritualRegister String?
  notes             String?
  isDefault         Boolean @default(false)

  voicePasses VoicePass[]

  @@index([scopeType])
  @@index([scopeId])
}

/// Alternate consciousness / voice renders and audio-ready text (reviewable).
model VoicePass {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaSceneId String?
  metaScene   MetaScene? @relation(fields: [metaSceneId], references: [id], onDelete: Cascade)

  personId String?
  person   Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  narrativePassId String?
  narrativePass   MetaSceneNarrativePass? @relation(fields: [narrativePassId], references: [id], onDelete: SetNull)

  voiceProfileId String?
  voiceProfile   NarrativeVoiceProfile? @relation(fields: [voiceProfileId], references: [id], onDelete: SetNull)

  passType String // pov_render, character_voice, narrator_voice, alternate_perspective, emotional_gravity, audio_script
  content  String  @db.Text
  summary  String?
  status   String // generated, accepted, revised, rejected, archived
  confidence Int?
  notes    String?

  @@index([metaSceneId])
  @@index([personId])
  @@index([narrativePassId])
  @@index([voiceProfileId])
  @@index([passType])
  @@index([status])
}

/// Durable character audio layer (samples, monologues, narration teasers).
model CharacterVoiceAsset {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  assetType String // sample, monologue, narration, teaser
  title     String
  audioUrl  String?
  transcript String? @db.Text
  status    String // draft, ready, published
  notes     String?

  @@index([personId])
  @@index([assetType])
  @@index([status])
}

/// Scene-scoped audio (narration, mixes, immersive excerpts).
model SceneAudioAsset {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
