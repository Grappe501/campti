  createdAt DateTime @default(now())

  analysisScope ProseQualityAnalysisScope @default(SCENE)

  /// Scene-scoped analysis ã set when `analysisScope` = SCENE.
  sceneId String?
  scene   Scene?   @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  /// Assembled chapter read ã set when `analysisScope` = CHAPTER_ASSEMBLY (sceneId null).
  chapterId String?
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  sceneDraftVersionId String?
  sceneDraftVersion   SceneDraftVersion? @relation(fields: [sceneDraftVersionId], references: [id], onDelete: SetNull)

  /// e.g. deterministic_v1, hybrid_ai_v1 (if a model augments heuristicsãstill stored as provisional).
  analyzerKind String

  /// sha256 hex of analyzed prose (dedupe / integrity).
  proseSha256 String

  reportJson Json

  /// Optional pointers to profiles used when scoring voice fit.
  narrativeVoiceProfileId String?
  characterVoicePersonId  String?

  authorGoalsSnapshot Json?

  /// Serialized `AnalyzeProseContext` + narrative ids so reports stay interpretable later.
  analyzerContextSnapshot Json?

  @@index([sceneId])
  @@index([chapterId])
  @@index([sceneDraftVersionId])
  @@index([analyzerKind])
  @@index([proseSha256])
  @@index([analysisScope])
}

model Symbol {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visibility      VisibilityStatus
  recordType      RecordType
  name            String
  meaning         String?
  /// Stage 2+: symbolic categories live in `RegistryValue` (family SYMBOLIC); this enum stays until a dedicated migration replaces it.
  category        SymbolCategory?
  sourceTraceNote String?

  /// Layered meaning (DNA); legacy `meaning` remains for older rows.
  meaningPrimary   String? @db.Text
  meaningSecondary String? @db.Text
  emotionalTone    String?
  usageContext     String?  @db.Text
  /// e.g. high, medium, low, interpretive, contested
  certainty String?
  /// Multi-layer tags from extraction: theme, symbol, rule, motif, etc.
  layers    Json?

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  scenes             Scene[]
  fragmentClusters   FragmentCluster[]

  @@index([sourceId])
}

